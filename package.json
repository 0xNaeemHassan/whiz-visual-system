{
  "name": "whiz-app",
  "private": true,
  "version": "8.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx && npm run check:chips",
    "test": "node scripts/test-smoke.mjs && node scripts/test-analytics-quality.mjs && node scripts/test-motion-reduction.mjs && node scripts/test-keyboard-flows.mjs && node scripts/test-frame-contract-fixtures.mjs && node scripts/test-frame-visual-fixtures.mjs && node scripts/test-frame-export-snapshot-fixtures.mjs && node scripts/test-frame-fixture-completeness.mjs",
    "check:chips": "node scripts/check-semantic-chips.mjs",
    "lint:naming": "eslint src --ext .js,.jsx --rule \"naming/file-naming-convention:error\" --rule \"naming/hook-api-naming:error\" --rule \"naming/service-symbol-naming:error\" --rule \"naming/comment-prefix-convention:error\"",
    "check:touch-targets": "node scripts/check-touch-targets.mjs",
    "check:perf": "node scripts/perf-smoke-check.mjs"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
